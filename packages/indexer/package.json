{
  "name": "@dac-cloud/indexer",
  "version": "0.1.0",
  "description": "Typed GraphQL query client for the DAC Cloud Envio indexer read-model.",
  "keywords": [
    "dac-cloud",
    "dao",
    "ethereum",
    "evm",
    "graphql",
    "indexer",
    "envio",
    "web3"
  ],
  "homepage": "https://github.com/DAC-cloud/dac-cloud-sdk/tree/master/packages/indexer#readme",
  "bugs": {
    "url": "https://github.com/DAC-cloud/dac-cloud-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DAC-cloud/dac-cloud-sdk.git",
    "directory": "packages/indexer"
  },
  "license": "Apache-2.0",
  "author": "DAC Cloud",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "codegen": "graphql-codegen --config codegen.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@graphql-typed-document-node/core": "^3.2.0",
    "graphql-request": "^7.3.1"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.7",
    "@graphql-codegen/typed-document-node": "^5.0.12",
    "@graphql-codegen/typescript": "^4.1.3",
    "@graphql-codegen/typescript-operations": "^4.6.1",
    "graphql": "^16.11.0"
  }
}
