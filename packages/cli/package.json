{
  "name": "@dac-cloud/cli",
  "version": "0.1.0",
  "description": "JSON-first CLI for operating DACs and Deals on the DAC Cloud protocol.",
  "keywords": [
    "dac-cloud",
    "dao",
    "cli",
    "ethereum",
    "evm",
    "governance",
    "deals",
    "web3"
  ],
  "homepage": "https://github.com/DAC-cloud/dac-cloud-sdk/tree/master/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/DAC-cloud/dac-cloud-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DAC-cloud/dac-cloud-sdk.git",
    "directory": "packages/cli"
  },
  "license": "Apache-2.0",
  "author": "DAC Cloud",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "dac": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@dac-cloud/core": "0.1.0",
    "@dac-cloud/indexer": "0.1.0",
    "@dac-cloud/manifests": "0.1.0",
    "commander": "^14.0.1",
    "dotenv": "^17.2.3",
    "viem": "^2.39.0",
    "zod": "^4.1.11"
  }
}
